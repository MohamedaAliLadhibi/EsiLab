# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (PostgreSQL) ────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lab_catalogue
DB_USER=postgres
DB_PASSWORD=esilabwebsite123adminkey123

# ── Redis (for import job queue) ─────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── Admin Security ───────────────────────────────────
# Comma-separated IP whitelist for the admin app

# ── File Storage ─────────────────────────────────────
# local | s3
STORAGE_DRIVER=local
UPLOAD_DIR=./storage/uploads
PUBLIC_ASSET_BASE_URL=http://localhost:3000/assets

# AWS S3 (only needed if STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=
CLOUDFRONT_BASE_URL=
